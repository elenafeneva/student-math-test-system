<Window x:Class="MathTaskValidator.App.TeacherResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teacher Results" Height="450" Width="600">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Enter Teacher Unique ID:" FontWeight="SemiBold" />
            <TextBox x:Name="TeacherIdInput" Width="250" Margin="0,5,0,10" />
            <Button Content="Load Students" Click="LoadStudents_Click" Width="120" />
            <ListBox x:Name="StudentsList" Margin="0,10,0,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StudentUniqueId}" Width="150" />
                            <TextBlock Text=" - " />
                            <TextBlock Text="{Binding Summary}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Window>