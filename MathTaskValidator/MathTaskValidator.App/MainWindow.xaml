<Window x:Class="MathTaskValidator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MathTaskValidator.App"
        mc:Ignorable="d"
        Title="MathTaskValidator" Height="450" Width="800">
    <Grid Margin="20">
        <!-- 1. ROLE SELECTION VIEW -->
        <StackPanel x:Name="RoleSelectionBox" VerticalAlignment="Center">
            <TextBlock Text="Welcome to Math Task Validator" FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <UniformGrid Columns="2" Height="100">
                <Button Content="Teacher" Margin="10" Click="TeacherMode_Click" Background="#007ACC" Foreground="White"/>
                <Button Content="Student" Margin="10" Click="StudentMode_Click" Background="#28A745" Foreground="White"/>
            </UniformGrid>
        </StackPanel>

        <!-- 2. TEACHER VIEW (Initially Hidden) -->
        <StackPanel x:Name="TeacherView" Visibility="Collapsed">
            <Button Content="← Back" HorizontalAlignment="Left" Click="Back_Click"/>
            <TextBlock Text="Teacher Dashboard" FontSize="18" Margin="0,10"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="Enter Teacher Unique ID:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TeacherIdBox" Width="250" Margin="0,0,0,15" Padding="5"/>

                    <TextBlock Text="Upload Exam XML File"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button Content="Choose File and Upload" Click="UploadButton_Click"/>
                        <Button Content="View Students Results" Margin="10,0,0,0" Click="OpenTeacherResultsWindow_Click"/>
                        <TextBlock x:Name="AttachedFilePath" Margin="10,0,0,0" VerticalAlignment="Center" Text="No file selected" Foreground="Gray"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 3. STUDENT VIEW (Initially Hidden) -->
        <StackPanel x:Name="StudentView" Visibility="Collapsed">
            <Button Content="← Back" HorizontalAlignment="Left" Click="Back_Click"/>
            <TextBlock Text="Student Exam Portal" FontSize="18" Margin="0,10"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="Enter Student Unique ID:"/>
                    <TextBox x:Name="StudentIdBox" Width="250" Margin="0,5,0,10" KeyDown="StudentIdBox_KeyDown" />

                    <TextBlock Text="Exam Results:"/>
                    <ListBox x:Name="ExamList" Height="100" Margin="0,10"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
